# ==============================================================================
# base-app — Environment Variables
#
# SETUP INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value below before running `npm start`
#   3. .env is git-ignored — never commit secrets
#
# For a complete setup walkthrough, see docs/NEW_APP_GUIDE.md
# ==============================================================================


# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
# Project URL format: https://<project-id>.supabase.co

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — only used in edge functions, never expose to client
# Find in: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Project ID — used in .cursor/rules/supabase-mcp.mdc (e.g. abcdefghijklmnop)
SUPABASE_PROJECT_ID=


# ── Auth Email — Supabase SMTP ────────────────────────────────────────────────
# Supabase uses SMTP for all built-in auth emails:
# password reset, invite, magic link, email confirmation
#
# Recommended providers: Resend (resend.com), Postmark, SendGrid, Mailgun
# Resend SMTP: smtp.resend.com, port 587, user = resend, pass = your API key
#
# Configure in: Supabase Dashboard → Authentication → SMTP Settings
# (The values below are what you paste into the Supabase dashboard, not used directly by the app)

SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=App Name


# ── Custom Transactional Email (Edge Function) ────────────────────────────────
# Used by supabase/functions/send-email/ for custom app emails
# (welcome, notifications, etc. — separate from Supabase auth emails)
#
# EMAIL_PROVIDER options: 'resend' | 'smtp'
# - resend: Requires RESEND_API_KEY
# - smtp:   Uses SMTP_* vars above

EMAIL_PROVIDER=resend
RESEND_API_KEY=


# ── Slack + Cursor Automation ─────────────────────────────────────────────────
# Powers the automated bug fix and feature request workflow.
# See docs/CURSOR_AUTOMATION_PROMPT.md for full setup instructions.
#
# SLACK_BOT_TOKEN: From Slack App → OAuth & Permissions → Bot User OAuth Token
# Channel IDs: Right-click channel in Slack → Copy Link → last segment of URL

SLACK_BOT_TOKEN=
SLACK_BUG_REPORTS_CHANNEL_ID=
SLACK_FEATURE_REQUESTS_CHANNEL_ID=

# Cursor API key — for the trigger-cursor-agent edge function
# Obtain from: https://cursor.com/settings → API Keys
CURSOR_API_KEY=


# ── App ───────────────────────────────────────────────────────────────────────
# Production URL — used in PWA manifest and email redirect links

APP_URL=https://your-app.netlify.app
