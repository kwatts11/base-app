{
  "name": "base-app-setup-wizard",
  "version": "1.0.0",
  "description": "Desktop setup wizard for base-app — clones the framework and generates a fully configured new project.",
  "repository": "https://github.com/kwatts11/base-app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "node --test \"test/**/*.test.js\""
  },
  "build": {
    "appId": "com.baseapp.setup-wizard",
    "productName": "Base-App Setup Wizard",
    "copyright": "MIT",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "templates/**/*",
      "renderer/**/*",
      "node_modules/pg/**/*",
      "node_modules/pg-types/**/*",
      "node_modules/pg-pool/**/*",
      "node_modules/pgpass/**/*",
      "node_modules/pg-int8/**/*",
      "node_modules/pg-protocol/**/*",
      "node_modules/pg-connection-string/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
