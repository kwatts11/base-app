# ==============================================================================
# base-app — .gitignore
# NOTE: Unlike derived apps, base-app COMMITS .agents/, .cursor/, docs/, PRD.md
# because those files ARE the framework.
# ==============================================================================

# ── Secrets (never commit) ────────────────────────────────────────────────────
.env
.env.local

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Expo / React Native ───────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native build artifacts ────────────────────────────────────────────────────
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.metro-health-check*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
lcov.info
*.lcov

# ── Build artifacts ───────────────────────────────────────────────────────────
build/
out/
.next/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── Temp ──────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── Package archives ──────────────────────────────────────────────────────────
*.tgz
*.tar.gz

# ── Supabase local dev ────────────────────────────────────────────────────────
supabase/.temp/
