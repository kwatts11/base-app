#### Development vs Production Behavior

**Automatic Environment Detection:**
- **Development builds**: Page IDs visible as small overlay (top-right corner)
- **Production builds**: Page IDs automatically hidden (returns null)
- **Testing**: Can be overridden for specific test scenarios

**Implementation Details:**
```typescript
// src/constants/buildConfig.ts
export function getBuildConfig(): BuildConfig {
  const isDevelopment = __DEV__;  // React Native's built-in flag
  
  return {
    showPageIds: isDevelopment,    // Auto-hide in production
    // ... other config
  };
}

// src/components/common/PageIdDisplay.tsx
export const PageIdDisplay: React.FC<PageIdDisplayProps> = ({ pageId }) => {
  // Only show in development builds
  if (!VERSION_CONFIG.showPageIds) {
    return null;  // Invisible in production
  }
  
  return (
    <View style={styles.container}>
      <Text style={styles.pageId}>{pageId}</Text>
      <Text style={styles.pageName}>{getPageName(pageId)}</Text>
    </View>
  );
};
```

